# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_twitch
DB_USER=bot_4_twitch
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== LOCAL BOT API ====================

# Telegram API (получить на https://my.telegram.org)
# Нужны только если используется Local Bot API (контейнер bot-api)
# для отправки файлов больше 50 МБ (Twitch VOD могут быть многочасовыми)
API_ID=
API_HASH=

# URL Local Bot API (внутри docker-compose это http://bot-api:8081)
# По умолчанию — публичный api.telegram.org (лимит 50 МБ)
BOT_API_URL=https://api.telegram.org

# ==================== КЭШ ====================

# Кэш скачиваний в БД (дни) — не перекачиваем одно и то же видео
CACHE_TTL_DAYS=1

# ==================== ПРОКСИ (ОПЦИОНАЛЬНО) ====================

# SOCKS5 или HTTP прокси на случай бана IP сервера в Twitch.
# Пусто = работаем напрямую. Применяется ко всем движкам (yt-dlp, ffmpeg, TWD).
# Формат: socks5://user:pass@host:port  или  http://user:pass@host:port
PROXY_URL=
